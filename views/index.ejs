<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blitz Defence</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <!-- Settings button -->
    <button id="settingsCornerBtn" class="settings-corner-btn" onclick="openSettings()" title="Settings">&#9881;</button>

    <!-- Audio elements -->
    <audio id="backgroundMusic" loop preload="auto">
        <source src="music/Background.m4a" type="audio/mp4">
    </audio>
    <audio id="enemyHit" loop preload="auto">
        <source src="sfx/enemyHit.wav" type="audio/wav">
    </audio>
    <audio id="enemyShot" loop preload="auto">
        <source src="sfx/enemyShot.wav" type="audio/wav">
    </audio>
    <audio id="playerHit" loop preload="auto">
        <source src="sfx/playerHit.wav" type="audio/wav">
    </audio>
    <audio id="playerShot" loop preload="auto">
        <source src="sfx/playerShot.wav" type="audio/wav">
    </audio>
    <audio id="railgunShot" loop preload="auto">
        <source src="sfx/railgunShot.wav" type="audio/wav">
    </audio>
    <audio id="slasherDash" loop preload="auto">
        <source src="sfx/slasherDash.wav" type="audio/wav">
    </audio>
    <audio id="playerDefeat" loop preload="auto">
        <source src="sfx/playerDefeat.wav" type="audio/wav">
    </audio>
    <audio id="bossDefeat" loop preload="auto">
        <source src="sfx/bossDefeat.wav" type="audio/wav">
    </audio>
    <audio id="settingOn" preload="auto">
        <source src="sfx/soundon.mp3" type="audio/mpeg">
    </audio>
    <audio id="settingOff" preload="auto">
        <source src="sfx/lightswitch.mp3" type="audio/mpeg">
    </audio>

    <div id="gameContainer">
        <canvas id="gameCanvas" width="1300" height="800"></canvas>

        <!-- Game UI (always visible during gameplay) -->
        <div id="gameUI">
            <div id="waves">Wave: <span id="currentWave">1</span> / <span id="totalWaves"></span></div>
            <!-- <div id="level">Level: <span id="levelValue">1</span></div>
            <div id="exp">EXP: <span id="expValue">0</span>/<span id="expMaxValue">100</span></div> -->
            <div id="health">Shield: <span id="healthValue">250</span>/<span id="healthMaxValue">250</span></div>
            <div id="money">Digipogs: <span id="moneyValue">250</span></div>

            <!-- <div class="progress-container">
                <div class="progress-bar">
                    <div class="progress-fill" id="expProgressFill"></div>
                </div>
                <span class="progress-label">Experience</span>
            </div> -->
        </div>

        <!-- Tower Shop  -->
        <div id="towerShop" class="hidden">
            <div class="tower-shop-header">
                <span class="tower-shop-label">Tower Shop</span>
                <span id="towerShopHint" class="tower-shop-hint">Select a tower to buy, then click the map to place it.</span>
            </div>
            <div id="towerShopCards" class="tower-shop-grid"></div>
        </div>

        <div id="towerUpgradePanel" class="hidden">
            <div id="towerUpgradeTitle" class="tower-upgrade-title">No Tower Selected</div>
            <div id="towerUpgradeBody" class="tower-upgrade-body">Click a placed tower to view upgrades.</div>
            <button id="towerUpgradeBtn" class="tower-upgrade-btn" disabled>Upgrade</button>
        </div>

        <!-- Start Menu -->
        <div id="startMenu" class="menu-overlay">
            <div class="menu-panel">
                <h1>Blitz Defence</h1>
                <p class="subtitle">Place towers to defend against waves of Blitzing Pixels.</p>
                <% if (isAdmin) { %>
                    <button id="adminPanelBtn" onclick="window.location.href='/admin'">Admin Panel</button>
                    <% } %>

                        <div class="menu-content">
                            <!-- Left side: Player preview -->
                            <!-- <div class="player-preview">
                                <h3>Hero Customization</h3>
                                <div id="playerPreview" class="preview-box">
                                    <div id="playerSprite" class="player-sprite"></div>
                                </div>
                                <div class="customization-controls">
                                    <button id="colorBtn" class="customize-btn">Change Color</button>
                                    <button id="shapeBtn" class="customize-btn">Change Inner Design</button>
                                    <button id="bodyShapeBtn" class="customize-btn">Change Body Shape</button>
                                </div>
                                <p class="hint">Click preview or buttons to customize</p>
                                <p class="preview-description">
                                    <strong>Ship Color:</strong> <span id="colorName">Green</span><br>
                                    <strong>Inner Design:</strong> <span id="shapeName">Triangle</span><br>
                                    <strong>Body Shape:</strong> <span id="bodyShapeName">Square</span>
                                </p>
                            </div> -->

                            <!-- Right side: Controls info -->
                            <div class="control-list">
                                <h3>How to Play</h3>
                                <div class="control-list">
                                    <div class="control-item">• Drag towers onto the map to place them</div>
                                    <div class="control-item">• Earn currency by defeating enemies</div>
                                    <div class="control-item">• Each enemy that reaches your base will depleat your sheild</div>
                                    <div class="control-item">• Run out of sheild - GAME OVER!</div>
                                    <div class="control-item">• Upgrade towers to increase power</div>
                                    <div class="control-item">• Survive waves and defeat bosses!</div>
                                    <button id="mapBtn" class="customize-btn">Change Map</button>
                                </div>
                            </div>
                        </div>

                        <div class="start-menu-bottom">
                            <button id="startBtn" class="primary-btn">START GAME</button>
                            <button class="settings-menu-btn" onclick="openSettings()">&#9881; Settings</button>
                        </div>
                        <p class="footer-text">Mouse to aim • Customize before starting</p>
            </div>
        </div>

        <!-- Pause Menu -->
        <div id="pauseMenu" class="menu-overlay hidden">
            <div class="menu-panel">
                <h1>PAUSED</h1>
                <div class="menu-buttons">
                    <button id="resumeBtn" class="primary-btn">Resume</button>
                    <button id="pauseRestartBtn" class="secondary-btn">Restart</button>
                    <button class="secondary-btn" onclick="openSettings()">&#9881; Settings</button>
                    <button id="quitBtn" class="secondary-btn">QUIT TO MENU</button>
                </div>
            </div>
        </div>

        <!-- Level Up Menu -->
        <!-- <div id="levelUpMenu" class="menu-overlay hidden">
            <div class="menu-panel">
                <h1 class="level-up-title">LEVEL UP!</h1>
                <p class="level-up-subtitle">Choose an upgrade:</p>
                <div id="upgradeOptions" class="upgrade-grid"> -->
                    <!-- Upgrade options populated by JavaScript -->
                <!-- </div>
                <p class="level-up-hint">Click an option or press 1, 2, or 3</p>
            </div>
        </div> -->

        <!-- Game Over Menu -->
        <div id="gameOver" class="menu-overlay hidden">
            <div class="menu-panel">
                <h1 class="game-over-title">GAME OVER!</h1>
                <div class="menu-buttons">
                    <button id="restartBtn" class="primary-btn">PLAY AGAIN</button>
                    <button id="mainMenuBtn" class="secondary-btn">MAIN MENU</button>
                </div>
            </div>
        </div>

        <!-- Settings Modal -->
        <div id="settingsModal" class="menu-overlay hidden" onclick="handleSettingsOverlayClick(event)">
            <div class="menu-panel settings-panel">
                <h2 class="settings-title">Settings</h2>

                <div class="settings-row">
                    <div class="settings-info">
                        <span class="settings-label">Wave Start</span>
                        <span class="settings-desc">Choose when new waves begin</span>
                    </div>
                    <div class="toggle-group">
                        <button class="toggle-btn" id="waveManualBtn" onclick="setSetting('waveAuto', false)">Manual</button>
                        <button class="toggle-btn" id="waveAutoBtn" onclick="setSetting('waveAuto', true)">Auto</button>
                    </div>
                </div>

                <div class="settings-row">
                    <div class="settings-info">
                        <span class="settings-label">Tooltips</span>
                        <span class="settings-desc">Show hints when hovering over elements and have helpful advice throughout the game</span>
                    </div>
                    <div class="toggle-group">
                        <button class="toggle-btn" id="tooltipsOnBtn" onclick="setSetting('tooltips', true)">On</button>
                        <button class="toggle-btn" id="tooltipsOffBtn" onclick="setSetting('tooltips', false)">Off</button>
                    </div>
                </div>

                <div class="settings-row">
                    <div class="settings-info">
                        <span class="settings-label">Sound</span>
                        <span class="settings-desc">Enable or disable all music and sound effects</span>
                    </div>
                    <div class="toggle-group">
                        <button class="toggle-btn" id="soundOnBtn" onclick="setSetting('sound', true)">On</button>
                        <button class="toggle-btn" id="soundOffBtn" onclick="setSetting('sound', false)">Off</button>
                    </div>
                </div>

                <button class="primary-btn" style="margin-top:20px" onclick="closeSettings()">Done</button>
            </div>
        </div>

        <!-- Victory Menu -->
        <div id="victoryMenu" class="menu-overlay hidden">
            <div class="menu-panel">
                <h1 class="victory-title">Victory!</h1>
                <div class="menu-buttons">
                    <!-- <button id="endlessBtn" class="primary-btn">ENDLESS MODE</button> -->
                    <button id="victoryRestartBtn" class="secondary-btn">PLAY AGAIN</button>
                    <button id="victoryMainMenuBtn" class="secondary-btn">MAIN MENU</button>
                </div>
            </div>
        </div>

    </div>

    <!-- Load JavaScript files in the correct order -->
    <script src="/socket.io/socket.io.js"></script>
    <script src="/game/player.js"></script>
    <script src="/game/enemy.js"></script>
    <script src="/game/boss.js"></script>
    <script src="/game/game.js"></script>
    <script src="/game/maps.js"></script>
    <script src="/game/towers.js"></script>
    <script src="/game/waves.js"></script>
    <script src="/game/main.js"></script>
    <script>
        // Settings
        const _defaultSettings = { waveAuto: false, tooltips: true, sound: true };

        function _loadSettings() {
            try {
                return Object.assign({}, _defaultSettings,
                    JSON.parse(localStorage.getItem('blitzDefenceSettings') || '{}'));
            } catch (e) {
                return Object.assign({}, _defaultSettings);
            }
        }

        function _saveSettings(s) {
            localStorage.setItem('blitzDefenceSettings', JSON.stringify(s));
        }

        function _applySettingsToGame(s) {
            if (window.game) {
                window.game.autoStart    = s.waveAuto;
                window.game.showTooltips = s.tooltips;
                window.game.soundEnabled = s.sound !== false;
                window.game.applySoundSetting();
            }
        }

        function _syncToggleUI(s) {
            document.getElementById('waveManualBtn').classList.toggle('active', !s.waveAuto);
            document.getElementById('waveAutoBtn').classList.toggle('active',    s.waveAuto);
            document.getElementById('tooltipsOnBtn').classList.toggle('active',  s.tooltips !== false);
            document.getElementById('tooltipsOffBtn').classList.toggle('active', s.tooltips === false);
            document.getElementById('soundOnBtn').classList.toggle('active',     s.sound !== false);
            document.getElementById('soundOffBtn').classList.toggle('active',    s.sound === false);
        }

        function _playToggleSound(value) {
            const sfx = document.getElementById(value ? 'settingOn' : 'settingOff');
            if (sfx) { sfx.currentTime = 0; sfx.play().catch(() => {}); }
        }

        function setSetting(key, value) {
            const s = _loadSettings();
            if (s[key] !== value) _playToggleSound(value);
            s[key] = value;
            _saveSettings(s);
            _applySettingsToGame(s);
            _syncToggleUI(s);
        }

        function openSettings() {
            const s = _loadSettings();
            _applySettingsToGame(s);
            _syncToggleUI(s);
            document.getElementById('settingsModal').classList.remove('hidden');
        }

        function closeSettings() {
            document.getElementById('settingsModal').classList.add('hidden');
        }

        function handleSettingsOverlayClick(e) {
            if (e.target === document.getElementById('settingsModal')) closeSettings();
        }

        // Apply saved settings whenever the game starts / restarts
        document.addEventListener('DOMContentLoaded', () => {
            const s = _loadSettings();
            _syncToggleUI(s);

            // Re-apply each time game starts (startBtn, restartBtn)
            ['startBtn','restartBtn','pauseRestartBtn','victoryRestartBtn'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.addEventListener('click', () => {
                    setTimeout(() => _applySettingsToGame(_loadSettings()), 50);
                });
            });
        });
    </script>

    <div class="payment-overlay" onclick="hidePayment()"></div>
    <div class="payment-content">
        <button onclick="hidePayment()" id="hide-payment">×</button>

        <div class="card">
            <h3 style="margin-top:0">Game Entry Payment</h3>
            <div class="row">
                <label class="small">PIN</label>
                <div>
                    <input id="pin" type="password" pattern="\d*" inputmode="numeric" maxlength="6"
                        placeholder="Enter your PIN" oninput="this.value = this.value.replace(/[^0-9]/g,'');">
                </div>
            </div>
            <div class="row price-display">
                <div class="price-content">
                    <span class="price-label">Game Entry Cost:</span>
                    <span class="price-amount" id="price">
                        <%= gamePrice %> Digipogs
                    </span>
                </div>
            </div>
            <div class="actions">
                <button class="primary" onclick="doTransfer();">Pay & Play</button>
            </div>
        </div>
    </div>

    </div>
</body>

</html>